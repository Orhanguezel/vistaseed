# vistaseeds Frontend - Production Environment Template
#
# Kullanim:
#   cp .env.production.example .env.local
#
# Bu dosyaya gercek secret yazma.
# `NEXT_PUBLIC_*` degiskenleri browser'a aciktir.

NEXT_PUBLIC_API_URL=https://api.vistaseeds.com.tr
NEXT_PUBLIC_SITE_URL=https://vistaseeds.com.tr
NEXT_PUBLIC_SENTRY_DSN=__FILL_PUBLIC_SENTRY_DSN__
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__FILL_BROWSER_RESTRICTED_MAPS_KEY__
