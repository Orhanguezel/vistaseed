# vistaseeds Admin Panel - Production Environment Template
#
# Kullanim:
#   cp .env.production.example .env
#
# Bu dosyaya gercek secret yazma.
# `NEXT_PUBLIC_*` degiskenleri browser'a aciktir.

# Backend origin (server-side fetch / rewrites)
PANEL_API_URL=https://api.vistaseeds.com.tr

# Public client config
NEXT_PUBLIC_API_URL=https://api.vistaseeds.com.tr/api
NEXT_PUBLIC_API_BASE_URL=https://api.vistaseeds.com.tr/api
NEXT_PUBLIC_MEDIA_URL=https://api.vistaseeds.com.tr/api
NEXT_PUBLIC_SOCKET_URL=https://api.vistaseeds.com.tr
NEXT_PUBLIC_SITE_URL=https://admin.vistaseeds.com.tr

# App metadata
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SITE_BRAND=vistaseeds

# Operational URLs
PLAYWRIGHT_BASE_URL=https://vistaseeds.com.tr

# Optional analytics / bot protection
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=__FILL_RECAPTCHA_SITE_KEY__
NEXT_PUBLIC_GA_ID=__FILL_GA_MEASUREMENT_ID__
NEXT_PUBLIC_GTM_guezelwebdesign=__OPTIONAL_GTM_CONTAINER_ID__
NEXT_PUBLIC_GTM_WV5FRN93=__OPTIONAL_GTM_CONTAINER_ID__
