NEXT_PUBLIC_API_URL=http://localhost:8083
PANEL_API_URL=http://localhost:8083
NEXT_PUBLIC_PANEL_API_URL=http://localhost:8083

# Cache temizleme (revalidate-proxy -> frontend /api/revalidate)
# PANEL_FRONTEND_URL frontend Next.js'in IC portuna isaret etmeli (nginx '/api/*'
# isteklerini backend'e yonlendirdigi icin public domain KULLANILMAZ; aksi halde
# /api/revalidate backend'e dusup 404 verir). Prod ornegi: http://127.0.0.1:3060
PANEL_FRONTEND_URL=http://127.0.0.1:3000
REVALIDATE_SECRET=change-me
