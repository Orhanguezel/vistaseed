# vistaseed Backend - Example Environment
#
# Kopyala:
#   cp .env.example .env
#
# Sonra kendi makine/ortam degerlerinle guncelle.

# ----------------------------------------------------------------------
# Genel
# ----------------------------------------------------------------------
NODE_ENV=development
PORT=8078
SENTRY_DSN=

# ----------------------------------------------------------------------
# Veritabani
# ----------------------------------------------------------------------
# Lokal docker-compose varsayilanlari:
# - DB_NAME=vistaseed
# - DB_USER=app
# - DB_PASSWORD=app
#
# Eger local MySQL kullaniyorsan bu kullanicinin `vistaseed` DB'sine
# erisim yetkisi olmasi gerekir.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vistaseed
DB_USER=app
DB_PASSWORD=app
DB_ROOT_USER=root
DB_ROOT_PASSWORD=root

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------
# Auth / Cookie
# ----------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# ----------------------------------------------------------------------
# URL'ler
# ----------------------------------------------------------------------
PUBLIC_URL=http://localhost:8078
FRONTEND_URL=http://localhost:3000
PUBLIC_API_BASE=http://localhost:8078

# ----------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------
# Virgul ile ayrilmis origin listesi.
CORS_ORIGIN=http://localhost:3000,http://localhost:3003,http://localhost:3002,http://localhost:3030

# ----------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------
# local | cloudinary
STORAGE_DRIVER=local

# Local storage
LOCAL_STORAGE_ROOT=/app/uploads
LOCAL_STORAGE_BASE_URL=/uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UNSIGNED_PRESET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=vistaseed
CLOUDINARY_BASE_PUBLIC=

# ----------------------------------------------------------------------
# SMTP / Mail
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=vistaseed <noreply@vistaseed.com>

# ----------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------
# AI / Harici servisler
# ----------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com

# ----------------------------------------------------------------------
# Seed / Gelistirme
# ----------------------------------------------------------------------
ALLOW_TEMP_LOGIN=1
TEMP_PASSWORD=admin123
ADMIN_EMAIL=admin@vistaseed.com
ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD
SEED_ADMIN_EMAIL=admin@vistaseed.com
SEED_ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD
CARRIER_EMAIL=satici@vistaseed.com
CARRIER_PASSWORD=Tasiyici@2026!
CARRIER_ID=b2c3d4e5-f6a7-8901-bcde-f23456789012
