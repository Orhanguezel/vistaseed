# Corporate Site Backend - Example Environment
#
# Kopyala:
#   cp .env.example .env
#
# Sonra kendi makine/ortam degerlerinle guncelle.

# ----------------------------------------------------------------------
# Genel
# ----------------------------------------------------------------------
NODE_ENV=development
PORT=8083
SITE_NAME=My Corporate Site
SENTRY_DSN=

# ----------------------------------------------------------------------
# Veritabani
# ----------------------------------------------------------------------
# Yerel: 127.0.0.1 | Docker Compose tam yığın: vistaseeds-db (servis adı)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mydb
DB_USER=app
DB_PASSWORD=app
DB_ROOT_USER=root
DB_ROOT_PASSWORD=root

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------
# Auth / Cookie
# ----------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# ----------------------------------------------------------------------
# URL'ler
# ----------------------------------------------------------------------
PUBLIC_URL=http://localhost:8083
FRONTEND_URL=http://localhost:3000
# Iyzico siparis callback yonlendirmesi: /{locale}/panel/siparisler
FRONTEND_DEFAULT_LOCALE=tr
PUBLIC_API_BASE=http://localhost:8083

# ----------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------
# Frontend (3000) + Admin panel (3030); virgülle ayırın
CORS_ORIGIN=http://localhost:3000,http://localhost:3030

# ----------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------
# local | cloudinary
STORAGE_DRIVER=local

# Local storage
LOCAL_STORAGE_ROOT=/app/uploads
LOCAL_STORAGE_BASE_URL=/uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UNSIGNED_PRESET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=uploads
CLOUDINARY_BASE_PUBLIC=

# ----------------------------------------------------------------------
# SMTP / Mail
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com

# ----------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------
# Seed / Gelistirme
# ----------------------------------------------------------------------
ALLOW_TEMP_LOGIN=1
TEMP_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD
# Bayi seed (010a): bayi@example.com — ADMIN_PASSWORD ile karistirilmaz
DEALER_PASSWORD=admin123
EDITOR_EMAIL=editor@example.com
EDITOR_PASSWORD=STRONG_EDITOR_PASSWORD

# ----------------------------------------------------------------------
# Blog — dis RSS ice aktarma (admin POST /api/v1/admin/blog/rss/import)
# ----------------------------------------------------------------------
# Virgulle ayirin. Bos birakilirsa ice aktarma sadece istek govdesindeki feed_urls ile calisir.
RSS_IMPORT_FEEDS=
RSS_IMPORT_LOCALE=tr
RSS_IMPORT_CATEGORY=haber
RSS_IMPORT_MAX_ITEMS_PER_FEED=20
RSS_IMPORT_MIN_INTERVAL_MS=900000
RSS_IMPORT_USER_AGENT=vistaseeds-RssImport/1.0

# ----------------------------------------------------------------------
# Odeme / Payment
# ----------------------------------------------------------------------
# Iyzico (kredi + kart akisi)
FEATURE_IYZICO_PAYMENT=0
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Banka sanal POS — kart odeme
# Kod hazir; saglayici bilgilerini doldurunca aktif etmek icin FEATURE_BANK_CARD_PAYMENT=1 yapin.
# Saglayici secimi: PAYMENT_CARD_PROVIDER=craftgate | nestpay_isbank | halkode | ziraatpay
FEATURE_BANK_CARD_PAYMENT=0
PAYMENT_CARD_PROVIDER=craftgate

# Craftgate (15+ banka tek entegrasyon)
# CRAFTGATE_API_KEY=
# CRAFTGATE_SECRET_KEY=
# CRAFTGATE_BASE_URL=https://sandbox-api.craftgate.io
# Canli: CRAFTGATE_BASE_URL=https://api.craftgate.io

# Is Bankasi — NestPay (EstV3Pos)
# NESTPAY_ISBANK_MERCHANT_ID=
# NESTPAY_ISBANK_API_USER=
# NESTPAY_ISBANK_API_PASS=
# NESTPAY_ISBANK_STORE_KEY=
# NESTPAY_ISBANK_API_URL=https://sanalpos.isbank.com.tr/fim/api
# NESTPAY_ISBANK_3D_URL=https://sanalpos.isbank.com.tr/fim/est3Dgate

# Halk Ode / CCPayment
# HALKODE_MERCHANT_ID=
# HALKODE_API_USER=
# HALKODE_API_PASS=
# HALKODE_STORE_KEY=
# HALKODE_3D_URL=https://sanalpos.halkbank.com.tr/halk/est3Dgate

# Ziraat Bankasi — ZiraatPay REST API v2
# ZIRAATPAY_MERCHANT=
# ZIRAATPAY_MERCHANT_USER=
# ZIRAATPAY_MERCHANT_PASSWORD=
# ZIRAATPAY_BASE_URL=https://test.ziraatpay.com.tr/ziraatpay/api/v2
# Canli: ZIRAATPAY_BASE_URL=https://vpos.ziraatpay.com.tr/ziraatpay/api/v2

# Dealer catalog: hangi product.item_type degerleri bayi kataloguna dahil
# Default: product (bos birakilabilir). Bereketfide gibi fide projelerinde bereketfide yapilir.
DEALER_CATALOG_ITEM_TYPES=product
