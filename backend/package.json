{
  "name": "corporate-site-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "test": "bun test src/test/",
    "test:auth": "bun test src/test/auth.test.ts",
    "test:api": "bun test src/test/api.test.ts",
    "test:category": "bun test src/test/category.test.ts",
    "typecheck": "bun x tsc --noEmit",
    "db:seed": "bun src/db/seed/index.ts",
    "db:seed:nodrop": "bun src/db/seed/index.ts --no-drop",
    "db:seed:only": "bun src/db/seed/index.ts --only="
  },
  "dependencies": {
    "@agro/shared-backend": "workspace:*",
    "@agro/shared-types": "workspace:*",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@sentry/node": "^10.45.0",
    "@types/geoip-lite": "^1.4.4",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "fastify": "^5",
    "geoip-lite": "^2.0.1",
    "google-auth-library": "^10.4.1",
    "iyzipay": "^2.0.64",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "puppeteer": "^24.40.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "0.25.11",
    "@types/node": "20",
    "@types/nodemailer": "^7.0.3",
    "@types/pdfkit": "^0.17.5",
    "bun-types": "^1.3.1",
    "esbuild": "0.25.11",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  }
}
