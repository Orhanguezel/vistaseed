# vistaseeds Backend - Production Environment Template
#
# Kullanim:
#   cp .env.production.example .env
#
# Sonra tum PLACEHOLDER alanlarini production degerlerinle doldur.
# Bu dosyaya gercek secret yazma.

# ----------------------------------------------------------------------
# Genel
# ----------------------------------------------------------------------
NODE_ENV=production
PORT=8083
SENTRY_DSN=__FILL_SENTRY_DSN__

# ----------------------------------------------------------------------
# Veritabani
# ----------------------------------------------------------------------
DB_HOST=__FILL_DB_HOST__
DB_PORT=3306
DB_NAME=vistaseeds
DB_USER=__FILL_DB_USER__
DB_PASSWORD=__FILL_DB_PASSWORD__
DB_ROOT_USER=__FILL_DB_ROOT_USER__
DB_ROOT_PASSWORD=__FILL_DB_ROOT_PASSWORD__

# ----------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------
REDIS_URL=redis://__FILL_REDIS_HOST__:6379
REDIS_HOST=__FILL_REDIS_HOST__
REDIS_PORT=6379
REDIS_PASSWORD=__FILL_REDIS_PASSWORD__

# ----------------------------------------------------------------------
# Auth / Cookie
# ----------------------------------------------------------------------
JWT_SECRET=__GENERATE_STRONG_RANDOM_64_PLUS__
COOKIE_SECRET=__GENERATE_ANOTHER_STRONG_RANDOM_64_PLUS__

# ----------------------------------------------------------------------
# URL'ler
# ----------------------------------------------------------------------
PUBLIC_URL=https://api.vistaseeds.com.tr
FRONTEND_URL=https://vistaseeds.com.tr
PUBLIC_API_BASE=https://api.vistaseeds.com.tr
BACKEND_URL=https://api.vistaseeds.com.tr

# ----------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------
CORS_ORIGIN=https://vistaseeds.com.tr,https://admin.vistaseeds.com.tr

# ----------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------
# local | cloudinary
STORAGE_DRIVER=cloudinary

# Local storage (sadece STORAGE_DRIVER=local ise kullan)
LOCAL_STORAGE_ROOT=/app/uploads
LOCAL_STORAGE_BASE_URL=/uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=__FILL_CLOUDINARY_CLOUD_NAME__
CLOUDINARY_API_KEY=__FILL_CLOUDINARY_API_KEY__
CLOUDINARY_API_SECRET=__FILL_CLOUDINARY_API_SECRET__
CLOUDINARY_UNSIGNED_PRESET=__FILL_CLOUDINARY_UNSIGNED_PRESET__
CLOUDINARY_UPLOAD_PRESET=__FILL_CLOUDINARY_UPLOAD_PRESET__
CLOUDINARY_FOLDER=vistaseeds
CLOUDINARY_BASE_PUBLIC=__FILL_CLOUDINARY_BASE_PUBLIC__

# ----------------------------------------------------------------------
# SMTP / Mail
# ----------------------------------------------------------------------
SMTP_HOST=__FILL_SMTP_HOST__
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=__FILL_SMTP_USER__
SMTP_PASS=__FILL_SMTP_PASS__
MAIL_FROM=vistaseeds <noreply@vistaseeds.com.tr>

# ----------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------
GOOGLE_CLIENT_ID=__FILL_GOOGLE_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__FILL_GOOGLE_CLIENT_SECRET__

# ----------------------------------------------------------------------
# Harici servisler
# ----------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=__FILL_GOOGLE_MAPS_API_KEY__
IYZICO_API_KEY=__FILL_IYZICO_API_KEY__
IYZICO_SECRET_KEY=__FILL_IYZICO_SECRET_KEY__
IYZICO_BASE_URL=https://api.iyzipay.com

# ----------------------------------------------------------------------
# Seed / Operator hesaplari
# ----------------------------------------------------------------------
ALLOW_TEMP_LOGIN=0
TEMP_PASSWORD=__DISABLED_IN_PRODUCTION__

ADMIN_EMAIL=__FILL_ADMIN_EMAIL__
ADMIN_PASSWORD=__FILL_ADMIN_PASSWORD__
SEED_ADMIN_EMAIL=__FILL_SEED_ADMIN_EMAIL__
SEED_ADMIN_PASSWORD=__FILL_SEED_ADMIN_PASSWORD__

CUSTOMER_EMAIL=__OPTIONAL_SEED_CUSTOMER_EMAIL__
CUSTOMER_PASSWORD=__OPTIONAL_SEED_CUSTOMER_PASSWORD__
CUSTOMER_ID=__OPTIONAL_SEED_CUSTOMER_UUID__

CARRIER_EMAIL=__OPTIONAL_SEED_CARRIER_EMAIL__
CARRIER_PASSWORD=__OPTIONAL_SEED_CARRIER_PASSWORD__
CARRIER_ID=__OPTIONAL_SEED_CARRIER_UUID__
